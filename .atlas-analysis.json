  "keyFeatures": [
    "SQL query editor with syntax highlighting and query history",
    "Table viewer with data browsing and inline editing",
    "Schema explorer with database tree navigation",
    "Encrypted backup and restore with AES-256",
    "Local-first architecture with browser storage",
    "Session management with PIN protection",
    "Notes and scratch pad for quick reference",
    "Export data to CSV, JSON, or Excel formats",
    "Multi-statement query execution with transaction support",
    "Connection pooling and query optimization"
  ],
  "publicApiSurface": [
    "POST /api/test-connection - Test database connection",
    "POST /api/query - Execute SQL queries",
    "GET /api/schema/tree - Fetch database schema tree",
    "GET /api/table-data - Retrieve table data with pagination",
    "GET /api/stats/pools - Get connection pool statistics",
    "GET /api/stats/cache - Get query cache statistics",
    "ServerConnection interface",
    "TableDefinition interface",
    "QueryExecutionResult interface",
    "DatabaseObject interface"
  ]
